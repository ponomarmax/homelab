{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homelab.local/schemas/payloads/muse/muse.ppg.v1-draft.schema.json",
  "title": "muse.ppg v1-draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "channels",
    "samples"
  ],
  "properties": {
    "channels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "offset_ns",
          "values"
        ],
        "properties": {
          "offset_ns": {
            "type": "integer",
            "minimum": 0
          },
          "values": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "number"
            }
          }
        }
      }
    }
  }
}

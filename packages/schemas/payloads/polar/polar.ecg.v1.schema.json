{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homelab.local/schemas/payloads/polar/polar.ecg.v1.schema.json",
  "title": "polar.ecg v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "samples"
  ],
  "properties": {
    "sample_rate_hz": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "units": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ecg_uv",
        "device_time_ns"
      ],
      "properties": {
        "ecg_uv": {
          "type": "string"
        },
        "device_time_ns": {
          "type": "string"
        }
      }
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "device_time_ns",
          "received_at_collector",
          "ecg_uv"
        ],
        "properties": {
          "device_time_ns": {
            "type": "integer",
            "minimum": 0
          },
          "received_at_collector": {
            "type": "string",
            "format": "date-time"
          },
          "ecg_uv": {
            "type": "number"
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homelab.local/schemas/payloads/polar/polar.hr.v1.schema.json",
  "title": "polar.hr v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "samples"
  ],
  "properties": {
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "received_at_collector",
          "hr",
          "ppgQuality",
          "correctedHr",
          "rrsMs",
          "rrAvailable",
          "contactStatus",
          "contactStatusSupported"
        ],
        "properties": {
          "received_at_collector": {
            "type": "string",
            "format": "date-time"
          },
          "hr": {
            "type": "integer",
            "minimum": 0
          },
          "ppgQuality": {
            "type": "integer"
          },
          "correctedHr": {
            "type": "integer",
            "minimum": 0
          },
          "rrsMs": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 0
            }
          },
          "rrAvailable": {
            "type": "boolean"
          },
          "contactStatus": {
            "type": "boolean"
          },
          "contactStatusSupported": {
            "type": "boolean"
          }
        }
      }
    }
  }
}

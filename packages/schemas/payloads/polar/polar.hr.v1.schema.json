{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homelab.local/schemas/payloads/polar/polar.hr.v1.schema.json",
  "title": "polar.hr v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "samples"
  ],
  "properties": {
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "offset_ns",
          "hr"
        ],
        "properties": {
          "offset_ns": {
            "type": "integer",
            "minimum": 0
          },
          "hr": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
